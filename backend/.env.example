# ============================================
# SENTINEL RBAC CONFIGURATION
# ============================================
# ⚠️  SECURITY WARNING: This file contains default values for DEVELOPMENT ONLY
# ⚠️  NEVER use these values in production environments
# ⚠️  Change ALL secrets and passwords before deploying

# ============================================
# VAULT CONFIGURATION (Recommended for Production)
# ============================================
# HashiCorp Vault provides secure secret management with:
# - Centralized secret storage
# - Secret rotation (TTL-based)
# - Access audit trails
# - Dynamic database credentials (future)
#
# When Vault is configured, secrets are read from Vault first,
# falling back to environment variables if Vault is unavailable.
#
# VAULT_ADDR=http://127.0.0.1:8200
# VAULT_TOKEN=your-vault-token
# VAULT_SECRET_PATH=secret/data/sentinel
# VAULT_NAMESPACE=                          # Optional: Vault Enterprise namespace
# SECRET_CACHE_TTL_MS=120000                # Optional: Secret cache TTL in milliseconds (default: 2 minutes)

# ============================================
# DATABASE CONFIGURATION
# ============================================
# PostgreSQL connection settings
# Required: PostgreSQL 12+ must be installed and running
# To create database: createdb sentinel_rbac
#
# Note: For production, store DB_PASSWORD in Vault:
# vault kv put secret/sentinel DB_PASSWORD=your-secure-password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sentinel_rbac
DB_USER=postgres
DB_PASSWORD=postgres

# ============================================
# JWT CONFIGURATION
# ============================================
# ⚠️  CRITICAL: JWT_SECRET MUST be set to a strong random value in production
# ⚠️  Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ⚠️  The application will NOT start without a valid JWT_SECRET
#
# For production, store in Vault:
# vault kv put secret/sentinel JWT_SECRET=$(node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=4000
NODE_ENV=development

# ============================================
# DEFAULT ADMIN CREDENTIALS (DEVELOPMENT ONLY)
# ============================================
# ⚠️  WARNING: Default admin account created by quick-setup.js:
# ⚠️  Email: admin@example.com
# ⚠️  Password: password123
# ⚠️  
# ⚠️  CHANGE THIS PASSWORD IMMEDIATELY after first login in production!
# ⚠️  Use: POST /auth/password-reset-request to reset the password

# ============================================
# EXTERNAL INTEGRATIONS & SERVICES
# ============================================
DOCKER_HOST=/var/run/docker.sock
LLAMA_ENDPOINT=http://localhost:11434
KESTRA_ENDPOINT=http://localhost:8080

# ============================================
# AI/LLM CONFIGURATION
# ============================================
# GROQ API key for AI-powered analysis (FinOps, incident analysis, etc.)
# Get your API key from: https://console.groq.com/
#
# For production, store in Vault:
# vault kv put secret/sentinel GROQ_API_KEY=your-groq-api-key
# GROQ_API_KEY=your-groq-api-key

# ============================================
# CHATOPS INTEGRATIONS
# ============================================
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
TEAMS_WEBHOOK_URL=

# ============================================
# NOTIFICATION EVENT PREFERENCES
# ============================================
NOTIFY_ON_INCIDENT=true
NOTIFY_ON_HEALING=true
