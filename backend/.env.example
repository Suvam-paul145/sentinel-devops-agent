# ============================================
# SENTINEL RBAC CONFIGURATION
# ============================================
# ⚠️  SECURITY WARNING: This file contains default values for DEVELOPMENT ONLY
# ⚠️  NEVER use these values in production environments
# ⚠️  Change ALL secrets and passwords before deploying

# ============================================
# DATABASE CONFIGURATION
# ============================================
# PostgreSQL connection settings
# Required: PostgreSQL 12+ must be installed and running
# To create database: createdb sentinel_rbac
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sentinel_rbac
DB_USER=postgres
DB_PASSWORD=postgres

# ============================================
# JWT CONFIGURATION
# ============================================
# ⚠️  CRITICAL: JWT_SECRET MUST be set to a strong random value in production
# ⚠️  Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ⚠️  The application will NOT start without a valid JWT_SECRET
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=4000
NODE_ENV=development

# ============================================
# DEFAULT ADMIN CREDENTIALS (DEVELOPMENT ONLY)
# ============================================
# ⚠️  WARNING: Default admin account created by quick-setup.js:
# ⚠️  Email: admin@example.com
# ⚠️  Password: password123
# ⚠️  
# ⚠️  CHANGE THIS PASSWORD IMMEDIATELY after first login in production!
# ⚠️  Use: POST /auth/password-reset-request to reset the password

# ============================================
# EXTERNAL INTEGRATIONS & SERVICES
# ============================================
DOCKER_HOST=/var/run/docker.sock
LLAMA_ENDPOINT=http://localhost:11434
KESTRA_ENDPOINT=http://localhost:8080

# ============================================
# CHATOPS INTEGRATIONS
# ============================================
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
TEAMS_WEBHOOK_URL=

# ============================================
# NOTIFICATION EVENT PREFERENCES
# ============================================
NOTIFY_ON_INCIDENT=true
NOTIFY_ON_HEALING=true

# ============================================
# MULTI-CLUSTER / MULTI-REGION CONFIGURATION
# ============================================
# Configure service registry for multi-cluster monitoring
# Options: 1. Set SERVICES_CONFIG as JSON string (see services.config.example.json)
#          2. Create backend/config/services.config.json file
#          3. Use default localhost configuration
# SERVICES_CONFIG={"clusters":{"local":{"label":"Local","region":"local","services":[{"name":"auth","url":"http://localhost:3001/health"}]}}}
#
# Service configuration can also be provided via:
# 1. SERVICES_CONFIG environment variable (JSON string)
# 2. services.config.json file in backend directory
#
# Example SERVICES_CONFIG (single line JSON):
# SERVICES_CONFIG={"clusters":[{"id":"local","name":"Local","region":"local","services":[{"name":"auth","url":"http://localhost:3001/health","type":"api","port":3001}]}]}
#
# For complex configurations, edit backend/services.config.json instead
# SERVICES_CONFIG=

# ============================================
# REMOTE AGENT CONFIGURATION
# ============================================
# Webhook secret for authenticating remote agent health reports
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# REMOTE_AGENT_WEBHOOK_SECRET=
AGENT_WEBHOOK_SECRET=

# ============================================
# AUTO-HEALING CONFIGURATION
# ============================================
# Auto-healing timeout in milliseconds (default: 300000 = 5 minutes)
# AUTO_HEAL_TIMEOUT_MS=300000
